{
  "name": "octobot",
  "version": "1.0.0",
  "description": "Modular AI agent framework with CLI and Feishu gateway.",
  "main": "dist/index.js",
  "bin": {
    "octobot": "bin/octobot"
  },
  "scripts": {
    "build": "tsc",
    "start": "ts-node src/cli.ts agent",
    "cli": "ts-node src/cli.ts",
    "dev": "nodemon --watch src --ext ts,md --exec \"ts-node src/cli.ts agent\"",
    "dev:gateway": "nodemon --watch src --ext ts,md --exec \"ts-node src/cli.ts gateway\"",
    "link": "npm link",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "release": "npm run build && npm publish --access public",
    "release:dry": "npm pack",
    "version:patch": "npm version patch -m \"chore: release %s\"",
    "version:minor": "npm version minor -m \"chore: release %s\"",
    "version:major": "npm version major -m \"chore: release %s\"",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["ai", "agent", "octobot", "cli", "feishu", "mcp", "typescript"],
  "author": "",
  "license": "MIT",
  "files": ["dist", "bin", "README.md", "LICENSE"],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yourusername/octobot.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/octobot/issues"
  },
  "homepage": "https://github.com/yourusername/octobot#readme",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.59.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@types/express": "^5.0.6",
    "chalk": "^5.4.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "ora": "^8.2.0",
    "jsonrepair": "^3.13.1",
    "openai": "^6.25.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@types/dotenv": "^6.1.1",
    "@types/node": "^25.3.2",
    "@types/ws": "^8.18.1",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
